class Solution
 {
public:
    int fib(int n)
    {
        if (n <= 1)
            return n;

        int a = 0, b = 1, c;

        for (int i = 2; i <= n; i++)
         {
            c = a + b;
            a = b;
            b = c;
        }

        return b;
    }
};
-------------------------------------------------------------------------------------------------------------------------------------
class Solution {
public:
    int dp[46];

    int climbStairs(int n) {
        if (n <= 2)
            return n;

        if (dp[n] != 0)
            return dp[n];

        return dp[n] = climbStairs(n - 1) + climbStairs(n - 2);
    }
};
