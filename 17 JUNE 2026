#include <iostream>
using namespace std;

int main() {
    int arr[5], sum = 0;

    // Input array elements
    cout << "Enter 5 elements: ";
    for(int i = 0; i < 5; i++) {
        cin >> arr[i];
        sum += arr[i];
    }

    // Display sum
    cout << "Sum of array elements = " << sum;

    return 0;
}
